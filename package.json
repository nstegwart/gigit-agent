{
  "name": "gigit-project-orchestration",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build && node scripts/align-ssr-style-urls.mjs && node scripts/assert-build-assets.mjs --write-manifest",
    "align-ssr-style-urls": "node scripts/align-ssr-style-urls.mjs",
    "assert-build-assets": "node scripts/assert-build-assets.mjs --write-manifest",
    "plain-language-lint": "node scripts/plain-language-lint.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:cp0": "vitest run --config qa/cp0/vitest.config.ts",
    "secret:scan": "node qa/cp0/secret-scan.mjs",
    "staging:gate": "node qa/cp0/staging-gate.mjs",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:unit": "node --input-type=module -e \"import{spawnSync}from'node:child_process';import{resolve}from'node:path';const v=resolve('node_modules/.bin/vitest');const a=process.argv.slice(1).filter(x=>x!=='--');process.exit(spawnSync(v,['run',...a],{stdio:'inherit',env:process.env}).status??1)\"",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "migrate": "node src/server/migrate-runner.mjs",
    "migrate:plan": "node src/server/migrate-runner.mjs plan",
    "migrate:dry-run": "node src/server/migrate-runner.mjs dry-run",
    "migrate:apply": "node src/server/migrate-runner.mjs apply",
    "migrate:status": "node src/server/migrate-runner.mjs status"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/match-sorter-utils": "latest",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "latest",
    "@tanstack/react-query": "latest",
    "@tanstack/react-query-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/react-store": "latest",
    "@tanstack/react-table": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "@tanstack/store": "latest",
    "lucide-react": "^0.545.0",
    "mysql2": "^3.22.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-event-client": "latest",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.20.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
