# Copy to .env. Defaults below are for LOCAL development.
#
# `pnpm dev` and `pnpm preview` both WRITE through these credentials, so a remote
# host here means every local page load and every MCP write mutates that board.
# db() therefore refuses any non-local CAIRN_DB_HOST unless CAIRN_ALLOW_REMOTE_DB=1.
CAIRN_DB_HOST=127.0.0.1
CAIRN_DB_PORT=3306
CAIRN_DB_USER=root
CAIRN_DB_PASSWORD=
CAIRN_DB_NAME=cairn_taskmanager

# Required by every mutating MCP tool, sent as the X-Cairn-Token header.
# Read tools need no auth. Use a throwaway value locally.
CAIRN_WRITE_TOKEN=dev-local-token-123

# CSRF secret. Required when CAIRN_ENV/APP_ENV is staging|production|prod
# (or NODE_ENV=production). Local/dev may omit and use the non-prod default.
# CAIRN_CSRF_SECRET=

# Optional CAIRN_BEARER_PRINCIPALS_JSON — JSON ARRAY of principal records
# (parseEnvBearerJson in src/server/rbac.ts). Object/map form is rejected.
# Required per usable record: secret, role (OWNER|ROOT_ORCHESTRATOR|AGENT|INTEGRATOR).
# Also set: tokenId, actorId. Optional: boardId, scopes, label, agentId, pathspecs.
# Local/harness synthetic only — use placeholders, never real secrets.
# Example (uncomment + replace secret before use):
# CAIRN_BEARER_PRINCIPALS_JSON=[{"tokenId":"local-root","secret":"REPLACE_ME_local_bearer_secret","role":"ROOT_ORCHESTRATOR","actorId":"local-root"}]

# Environment class hint for CSRF + ops (local omit; staging compose sets staging).
# CAIRN_ENV=local

# Deployed box ONLY. Unset on laptops — it is the guard that stops a dev run
# from writing to a remote board.
# CAIRN_ALLOW_REMOTE_DB=1

# --- Staging compose (see deploy/staging/) ---
# Staging stack secrets live in untracked deploy/staging/.env
# (template: deploy/staging/env.staging.example). Do not put staging secrets here.
#
# Forced by deploy/staging/docker-compose.yml on the VPS:
#   CAIRN_DB_HOST=cairn-tm-v3-mysql
#   CAIRN_DB_NAME=cairn_tm_v3_staging
#   CAIRN_STAGING_DB_HOSTS=cairn-tm-v3-mysql
#   CAIRN_ALLOW_REMOTE_DB=1
#   CAIRN_DEPLOYED_SHA / CAIRN_EXPECTED_SHA = RELEASE_SHA
#   bind 127.0.0.1:33211 -> app:3210
#   health: GET /api/healthz
#
# Host class STAGING requires CAIRN_STAGING_DB_HOSTS to include the Docker DNS name
# (cairn-tm-v3-mysql). Without it, classifyDbHost returns UNKNOWN_REMOTE.
# CAIRN_STAGING_DB_HOSTS=cairn-tm-v3-mysql
# CAIRN_SCHEMA_VERSION=005
# CAIRN_MIGRATION_LATEST=005
# CAIRN_HEALTH_BOARD_ID=mfs-rebuild-staging-synth
