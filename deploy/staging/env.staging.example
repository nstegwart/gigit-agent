# Staging secrets + release pin for docker compose (TM-P0 / cairn-tm-v3).
#
# Copy to deploy/staging/.env (UNTRACKED — matched by root .gitignore pattern `.env`).
#   cp deploy/staging/env.staging.example deploy/staging/.env
# Then replace every REPLACE_ME value with staging-only secrets.
#
# Never reuse non-staging credentials. Synthetic data only.
# This file is safe to commit; deploy/staging/.env is not.

# Full git SHA of the release being built/deployed (40 hex chars).
RELEASE_SHA=0000000000000000000000000000000000000000

# MySQL bootstrap (container cairn-tm-v3-mysql, database cairn_tm_v3_staging).
MYSQL_ROOT_PASSWORD=REPLACE_ME_staging_root_password

# App DB credentials (host/name are forced by compose to cairn-tm-v3-mysql / cairn_tm_v3_staging).
CAIRN_DB_USER=cairn_tm_v3
CAIRN_DB_PASSWORD=REPLACE_ME_staging_app_password

# Auth — staging-only throwaway values.
CAIRN_WRITE_TOKEN=REPLACE_ME_staging_write_token
CAIRN_CSRF_SECRET=REPLACE_ME_staging_csrf_secret_min_32_chars_long
# Optional CAIRN_BEARER_PRINCIPALS_JSON — MUST be a JSON ARRAY of principal records
# (parseEnvBearerJson). Object/map form is rejected. Valid roles: OWNER |
# ROOT_ORCHESTRATOR | AGENT | INTEGRATOR (not ROOT). Each usable record needs
# secret + role; include tokenId + actorId. Optional: boardId, scopes, label.
# Staging synthetic only — never reuse real secrets. REPLACE_ME is a placeholder.
# Dual-principal MCP smoke needs BOTH a ROOT_ORCHESTRATOR and an AGENT principal
# (register_run / heartbeat_run are agent-scoped; publish/get_next/sync are root-scoped).
# CAIRN_BEARER_PRINCIPALS_JSON=[{"tokenId":"staging-root","secret":"REPLACE_ME_staging_bearer_secret","role":"ROOT_ORCHESTRATOR","actorId":"staging-root","boardId":"mfs-rebuild-staging-synth"},{"tokenId":"staging-agent","secret":"REPLACE_ME_staging_agent_bearer_secret","role":"AGENT","actorId":"staging-agent","agentId":"staging-agent","boardId":"mfs-rebuild-staging-synth"}]
#
# Client-side dual-principal smoke (laptop / SSH tunnel — not compose app env):
#   STAGING_ROOT_BEARER_TOKEN=<ROOT_ORCHESTRATOR secret>   # preferred; fallback STAGING_BEARER_TOKEN
#   STAGING_AGENT_BEARER_TOKEN=<AGENT secret>              # required for --real (fail-closed)
#   STAGING_AGENT_ID=<AGENT actorId/agentId>              # ownRun match for register_run

# Health / schema expectations (SHA also injected as CAIRN_DEPLOYED_SHA / CAIRN_EXPECTED_SHA by compose).
CAIRN_SCHEMA_VERSION=007
CAIRN_MIGRATION_LATEST=007
# Prefer synthetic board id after fixtures load (optional until seed exists).
# CAIRN_HEALTH_BOARD_ID=mfs-rebuild-staging-synth

# Optional migration applied CSV fallback if schema_migrations table not yet readable.
# CAIRN_MIGRATION_APPLIED=
