# Production release approval + ops template (UNTRACKED secrets live in host .env).
# Copy values into the operator shell or a root-owned approval file — NEVER commit real secrets.
#
# Evidence contract: WORKER_RESULT_investigate-final-production-502-r3.md
#   path=/home/gian.devx/cairn-taskmanager  listen=127.0.0.1:3210  pm2=cairn-taskmanager

# --- Fail-closed approval bundle (required for ANY mutating script) ---
# APPROVED_FULL_SHA must be canonical lowercase 40-char hex (uppercase rejected).
APPROVED_FULL_SHA=0000000000000000000000000000000000000000
PRODUCTION_APPROVAL_ID=REPLACE_ME_owner_ticket_or_approval_id
# Path to dump receipt or SQL dump file that proves backup authority (must exist, non-empty)
BACKUP_RECEIPT=/path/to/fresh-db-dump-or-receipt.txt
# Optional: max age of backup receipt for migrate apply (hours)
BACKUP_MAX_AGE_HOURS=24

# --- Migrate apply (default off) ---
# MIGRATE_APPLY_APPROVED=1
# DB_DUMP_PATH=/path/to/same-or-other-fresh-dump.sql
# Exact migration/release/database binding (required; lowercase hashes only).
# ONE-STEP only: approve the exact NEXT pending manifest version (NNN), never a skip
# and never "all remaining". Product tip is 014; CP0 historical baseline is 008.
# Example for next=009 after 008 is applied:
# MIGRATION_APPROVED_VERSION=009
# MIGRATION_APPROVED_SHA256=<sha256 of migrations/009_rebuild_lineage.sql>
# MIGRATION_TARGET_HOST=<exact CAIRN_DB_HOST>
# MIGRATION_TARGET_DATABASE=<exact CAIRN_DB_NAME>
# MIGRATION_APPROVAL_BINDING=<sha256 of release SHA, approval id, version, migration sha, host, db, backup sha joined by NUL>

# --- App path overrides (production host defaults) ---
# PROD_APP_PATH=/home/gian.devx/cairn-taskmanager
# PROD_ENV_FILE=/home/gian.devx/cairn-taskmanager/.env
# PROD_NGINX_SITE=/etc/nginx/sites-available/task-manager.mfsdev.net.conf
# PROD_LISTEN_PORT=3210
# PROD_APP_NAME=cairn-taskmanager
# PROD_SYSTEMD_UNIT=pm2-gian.devx.service
# PROD_PUBLIC_HOST=task-manager.mfsdev.net

# --- Dry-run DEFAULT-ON (PRODUCTION_DRY_RUN defaults to 1 when unset) ---
# PRODUCTION_DRY_RUN=1
# Real mutation requires BOTH:
# PRODUCTION_DRY_RUN=0
# PRODUCTION_MUTATION_APPROVED=1
# (+ approval triple above). Laptop dry-run does not need pm2 binary.

# --- Host .env keys required (values live ONLY on server .env — list for ops) ---
# CAIRN_DB_HOST=
# CAIRN_DB_PORT=3306
# CAIRN_DB_USER=
# CAIRN_DB_PASSWORD=
# CAIRN_DB_NAME=cairn_taskmanager
# CAIRN_WRITE_TOKEN=
# CAIRN_ALLOW_REMOTE_DB=1
# CAIRN_CSRF_SECRET=
# CAIRN_BEARER_PRINCIPALS_JSON=
# Product schema latest (manifest tip). CP0 baseline remains 008.
# CAIRN_SCHEMA_VERSION=014
# CAIRN_MIGRATION_LATEST=014

# --- Health readback (optional bearer for release PASS) ---
# CAIRN_HEALTH_TOKEN=
