{
  "packetId": "priority-matrix-v1",
  "ac": ["AC-PRIORITY-01", "AC-PRIORITY-02"],
  "scenarios": [
    {
      "id": "no_frontier",
      "description": "No ACTIVE PRODUCT membership → majorityAllocationPass null, frontier empty",
      "input": {
        "membershipTaskIds": [],
        "packets": []
      },
      "expect": {
        "membershipDenominator": 0,
        "priorityCapacityShare": null,
        "majorityAllocationPass": null,
        "frontierState": "PRIORITY_FRONTIER_EMPTY",
        "allClosureCapacity": 0
      }
    },
    {
      "id": "zero_capacity",
      "description": "Membership exists but zero schedulable packets → share null, majority false",
      "input": {
        "membershipTaskIds": ["synth-gate-pri-t1"],
        "packets": [
          {
            "packetId": "synth-gate-pkt-blocked",
            "taskId": "synth-gate-pri-t1",
            "isPriorityPortfolio": true,
            "excluded": true,
            "liveOrReserved": false,
            "genuine": true,
            "unique": true,
            "currentHash": true,
            "dependencyReady": true,
            "collisionSafe": true,
            "advancesOpenClosureGate": true
          }
        ]
      },
      "expect": {
        "membershipDenominator": 1,
        "priorityCapacityShare": null,
        "majorityAllocationPass": false,
        "frontierState": "PRIORITY_FRONTIER_ACTIVE",
        "reason": "ZERO_SCHEDULABLE_CAPACITY",
        "allClosureCapacity": 0
      }
    },
    {
      "id": "majority",
      "description": "Priority packets majority of schedulable → majorityAllocationPass true",
