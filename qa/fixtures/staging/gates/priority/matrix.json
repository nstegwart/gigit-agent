        "priorityCapacityShare": 0.6666666666666666,
        "majorityAllocationPass": true,
        "frontierState": "PRIORITY_FRONTIER_ACTIVE"
      }
    },
    {
      "id": "fail_safe_non_majority",
      "description": "Priority share ≤0.5 → majorityAllocationPass false",
