            "advancesOpenClosureGate": true
          },
          {
            "packetId": "synth-gate-pkt-p2",
            "taskId": "synth-gate-pri-t2",
            "isPriorityPortfolio": true,
            "excluded": false,
            "liveOrReserved": true,
            "genuine": true,
            "unique": true,
            "currentHash": true,
            "dependencyReady": true,
            "collisionSafe": true,
            "advancesOpenClosureGate": true
          },
          {
            "packetId": "synth-gate-pkt-other",
            "taskId": "synth-gate-other-t",
