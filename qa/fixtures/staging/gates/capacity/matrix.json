{
  "packetId": "capacity-matrix-v1",
  "ac": ["AC-CAP-01", "AC-CAP-02", "AC-CAP-03", "AC-ACCOUNT-07"],
  "scenarios": [
    {
      "id": "zero_capacity_stale",
      "description": "forceZero/stale account-sync → usableCapacity=0 fail-closed",
      "input": {
        "accounts": [
          {
            "maskedAccountId": "synth-gate-acc-g1",
            "status": "OK",
            "providerKind": "GROK",
            "effectiveInUse": 0,
            "effectiveCap": 5,
            "physicalSlotsDisplay": null,
            "adaptiveQuotaState": null,
            "reason": null,
            "statusChangedAt": null,
            "tombstone": false
          }
        ],
        "forceZero": true
      },
      "expect": {
        "usableCapacity": 0,
        "dispatchMode": "BLOCKED",
        "limitingReasonsIncludes": ["ACCOUNT_SYNC_STALE"]
      }
    },
    {
      "id": "below_floor",
