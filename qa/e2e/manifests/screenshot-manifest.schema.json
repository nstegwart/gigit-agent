{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cairn.local/schemas/screenshot-manifest.schema.json",
  "title": "Cairn UI_CONTRACT §13 Screenshot Manifest",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "rows"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "TM_UI_CONTRACT_V1"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "rows": {
      "type": "array",
      "items": { "$ref": "#/$defs/row" }
    }
  },
  "$defs": {
    "row": {
      "type": "object",
      "required": [
        "route",
        "state",
        "stagingUrl",
        "fullSha",
        "schemaVersion",
        "canonicalSnapshotId",
        "canonicalHash",
        "boardRev",
        "lifecycleRev",
        "capturedAt",
        "browserTestId",
        "accessibilityResult",
        "missionQuestionLink"
      ],
      "anyOf": [
        { "required": ["viewport"] },
        { "required": ["zoom"] }
      ],
      "properties": {
        "route": { "type": "string", "minLength": 1 },
        "state": {
          "type": "string",
          "enum": [
            "populated",
            "loading",
            "empty",
            "zero-results",
            "partial",
            "stale",
            "disconnected",
            "error",
            "forbidden",
            "needs-human"
          ]
        },
        "viewport": { "type": "string" },
        "zoom": { "type": "string" },
        "stagingUrl": { "type": "string", "minLength": 1 },
        "fullSha": { "type": "string", "minLength": 1 },
        "schemaVersion": { "type": "string" },
        "canonicalSnapshotId": { "type": "string", "minLength": 1 },
        "canonicalHash": { "type": "string", "minLength": 1 },
        "boardRev": { "type": "string", "minLength": 1 },
        "lifecycleRev": { "type": "string", "minLength": 1 },
        "capturedAt": { "type": "string" },
        "browserTestId": { "type": "string", "minLength": 1 },
        "accessibilityResult": { "type": "string", "minLength": 1 },
        "missionQuestionLink": {
          "type": ["string", "null"],
          "pattern": "^Q[1-8]$"
        },
        "visualDiff": { "type": "string" },
        "pinFields": { "type": "string", "enum": ["PRESENT", "MISSING"] },
        "screenshotPath": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
